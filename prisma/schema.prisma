generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id         String   @id @default(cuid())
  firstName  String?
  lastName   String?
  middleName String?
  suffix     String?

  email      String   @unique
  password   String?

  createdAt  DateTime @default(now())

  fieldId    String?
  field      Field?   @relation(fields: [fieldId], references: [id])

  accounts   Account[]
  sessions   Session[]
  workHours  WorkHours[]
  requiredHours RequiredHours?

  @@map("users")
}

model Field {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  courses   Course[]
  users     User[]

  @@map("fields")
}

model Course {
  id        String   @id @default(cuid())
  name      String
  code      String?  @unique
  createdAt DateTime @default(now())

  fieldId   String
  field     Field    @relation(fields: [fieldId], references: [id])

  @@map("courses")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model WorkHours {
  id          String    @id @default(cuid())
  userId      String
  
  date        DateTime  @db.Date
  
  // @db.Time ensures MySQL uses its native TIME type (e.g., "08:00:00")
  time_in_am  DateTime? @db.Time
  time_out_am DateTime? @db.Time
  time_in_pm  DateTime? @db.Time
  time_out_pm DateTime? @db.Time

  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("work_hours")
}

model RequiredHours {
  id        String   @id @default(cuid())
  userId    String   @unique
  hours     Float    
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Automatically updates on modification

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("required_hours")
}